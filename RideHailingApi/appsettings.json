{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Chúng ta sẽ định nghĩa 3 tên Server phổ biến nhất mà team bạn đang dùng
  "AvailableServers": [
    ".\\SQLEXPRESS", // Dành cho máy cài bản Express (như máy bạn)
    ".", // Dành cho máy cài bản Developer (Default Instance)
    "(localdb)\\MSSQLLocalDB" // Dành cho máy xài trực tiếp Visual Studio Server Explorer
  ],

  // ConnectionString bây giờ không chứa tên Server nữa, chỉ chứa tên DB
  "ConnectionStrings": {
    "North_Primary": "Database=RideHailing_North;TrustServerCertificate=True;Integrated Security=True",
    "North_Replica": "Database=RideHailing_North_Replica;TrustServerCertificate=True;Integrated Security=True",
    "South_Primary": "Database=RideHailing_South;TrustServerCertificate=True;Integrated Security=True",
    "South_Replica": "Database=RideHailing_South_Replica;TrustServerCertificate=True;Integrated Security=True"
  }
}