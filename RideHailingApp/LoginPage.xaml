<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RideHailingApp.LoginPage"
    NavigationPage.HasBackButton="False"
    Shell.NavBarIsVisible="False"
    Title="Đăng nhập"
    BackgroundColor="#0F1117">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto" MinimumHeightRequest="700">

            <!-- ===== HEADER / BRAND ===== -->
            <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="32,60,32,0">

                <!-- Icon xe -->
                <Border BackgroundColor="#00C853"
                        StrokeThickness="0"
                        WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="🚗"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="RideNow"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,16,0,4"/>

                <Label Text="Di chuyển thông minh, kết nối nhanh"
                       FontSize="14"
                       TextColor="#8A8FA3"
                       HorizontalOptions="Center"
                       Margin="0,0,0,40"/>

            </VerticalStackLayout>

            <!-- ===== FORM ===== -->
            <VerticalStackLayout Grid.Row="1" Padding="28,0" Spacing="16" VerticalOptions="Center">

                <!-- Banner trạng thái server (ẩn mặc định) -->
                <Border x:Name="ServerBanner"
                        IsVisible="False"
                        BackgroundColor="#1A2A1A"
                        StrokeThickness="1"
                        Stroke="#00C853"
                        Padding="14,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📡" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="ServerBannerText"
                               Text="Đang kết nối Server Miền Nam..."
                               TextColor="#00C853"
                               FontSize="13"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Banner Read-Only cảnh báo -->
                <Border x:Name="ReadOnlyBanner"
                        IsVisible="False"
                        BackgroundColor="#2A2200"
                        StrokeThickness="1"
                        Stroke="#FFC107"
                        Padding="14,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚠️" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="Server chính gặp sự cố. Đang dùng bản sao dự phòng — chỉ xem được lịch sử."
                               TextColor="#FFC107"
                               FontSize="12"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Label Email -->
                <Label Text="Email" TextColor="#8A8FA3" FontSize="13" Margin="4,0,0,0"/>

                <!-- Email Entry -->
                <Border BackgroundColor="#1C1F2E"
                        StrokeThickness="1"
                        Stroke="#2E3348"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Entry x:Name="EmailEntry"
                           Placeholder="Nhập email của bạn"
                           PlaceholderColor="#4A5068"
                           TextColor="White"
                           Keyboard="Email"
                           BackgroundColor="Transparent"
                           Margin="16,12"/>
                </Border>

                <!-- Label Password -->
                <Label Text="Mật khẩu" TextColor="#8A8FA3" FontSize="13" Margin="4,4,0,0"/>

                <!-- Password Entry -->
                <Border BackgroundColor="#1C1F2E"
                        StrokeThickness="1"
                        Stroke="#2E3348"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Nhập mật khẩu"
                           PlaceholderColor="#4A5068"
                           TextColor="White"
                           IsPassword="True"
                           BackgroundColor="Transparent"
                           Margin="16,12"/>
                </Border>

                <!-- Error Label -->
                <Label x:Name="ErrorLabel"
                       TextColor="#FF5252"
                       FontSize="13"
                       IsVisible="False"
                       HorizontalOptions="Center"
                       Margin="0,4,0,0"/>

                <!-- Nút Đăng nhập -->
                <Button Text="Đăng nhập"
                        x:Name="LoginButton"
                        BackgroundColor="#00C853"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="54"
                        Margin="0,8,0,0"
                        Clicked="OnLoginClicked"/>

                <!-- Hoặc -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,8">
                    <BoxView HeightRequest="1" WidthRequest="80" BackgroundColor="#2E3348" VerticalOptions="Center"/>
                    <Label Text="hoặc" TextColor="#4A5068" FontSize="13" VerticalOptions="Center"/>
                    <BoxView HeightRequest="1" WidthRequest="80" BackgroundColor="#2E3348" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Thông tin server đang kết nối + Picker chọn thủ công -->
                <Border BackgroundColor="#13161F"
                        StrokeThickness="1"
                        Stroke="#2E3348"
                        Padding="14,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <!-- Hàng 1: Trạng thái khu vực -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🌐" FontSize="16" VerticalOptions="Center" Margin="0,0,8,0"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Vùng kết nối" TextColor="#4A5068" FontSize="11"/>
                                <Label x:Name="RegionLabel"
                                       Text="Đang xác định vị trí..."
                                       TextColor="#8A8FA3"
                                       FontSize="13"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   x:Name="ServerStatusDot"
                                   Text="●"
                                   TextColor="#FFC107"
                                   FontSize="12"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <!-- Hàng 2: Picker chọn tỉnh/thành phố (giả lập GPS) -->
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
                            <Label Text="📍" FontSize="13" VerticalOptions="Center" Margin="0,0,6,0"/>
                            <Picker x:Name="RegionPicker"
                                    Grid.Column="1"
                                    Title="Chọn tỉnh/thành phố (demo)"
                                    TextColor="#8A8FA3"
                                    TitleColor="#4A5068"
                                    BackgroundColor="Transparent"
                                    SelectedIndexChanged="OnRegionPickerChanged">
                                <Picker.Items>
                                    <x:String>Hà Nội (Miền Bắc)</x:String>
                                    <x:String>Hải Phòng (Miền Bắc)</x:String>
                                    <x:String>Đà Nẵng (Miền Bắc)</x:String>
                                    <x:String>TP. Hồ Chí Minh (Miền Nam)</x:String>
                                    <x:String>Cần Thơ (Miền Nam)</x:String>
                                    <x:String>Bình Dương (Miền Nam)</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!-- ===== FOOTER ===== -->
            <VerticalStackLayout Grid.Row="2" Padding="28,0,28,48" Spacing="12">

                <Button Text="Chưa có tài khoản? Đăng ký ngay"
                        BackgroundColor="Transparent"
                        TextColor="#00C853"
                        FontSize="14"
                        BorderWidth="0"
                        Clicked="OnGoToRegisterClicked"/>

            </VerticalStackLayout>

        </Grid>
    </ScrollView>

</ContentPage>
