<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RideHailingApp.ProfilePage"
    Shell.NavBarIsVisible="False"
    Title="Hồ sơ"
    BackgroundColor="{AppThemeBinding Dark=#0F1117, Light=#F5F5F5}">

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,32">

            <!-- ===== HEADER ===== -->
            <Grid BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#FFFFFF}" Padding="20,52,20,24">

                <!-- Banner READ-ONLY -->
                <Border x:Name="ReadOnlyBanner"
                        IsVisible="False"
                        BackgroundColor="#2A2200"
                        StrokeThickness="1"
                        Stroke="#FFC107"
                        Padding="12,8"
                        Margin="0,0,0,16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚠️" FontSize="13"/>
                        <Label Text="Server chính gặp sự cố — Đang dùng bản sao. Một số tính năng bị tạm khóa."
                               TextColor="#FFC107" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Avatar + Tên + Email -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16" VerticalOptions="End">

                    <!-- Avatar tròn -->
                    <Border BackgroundColor="#00C853"
                            StrokeThickness="0"
                            WidthRequest="70" HeightRequest="70">
                        <Border.StrokeShape><RoundRectangle CornerRadius="35"/></Border.StrokeShape>
                        <Label Text="{Binding UserInitial}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding UserName}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}"/>
                        <Label Text="{Binding UserEmail}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}"/>
                        <!-- Badge server -->
                        <Border BackgroundColor="{AppThemeBinding Dark=#0D2E1A, Light=#E8F5E9}"
                                StrokeThickness="0"
                                Padding="8,3"
                                HorizontalOptions="Start">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Label x:Name="ServerBadge"
                                   Text="● Server Miền Nam"
                                   TextColor="#00C853"
                                   FontSize="11"/>
                        </Border>
                    </VerticalStackLayout>

                </Grid>
            </Grid>

            <!-- ===== THỐNG KÊ ===== -->
            <Grid ColumnDefinitions="*,*,*"
                  BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#FFFFFF}"
                  Padding="16,0,16,20"
                  Margin="0,1,0,0"
                  ColumnSpacing="8">

                <Border BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}" Padding="12,10" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TripCount}" FontSize="22" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}" HorizontalOptions="Center"/>
                        <Label Text="Chuyến đi" TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}" Padding="12,10" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalSpent}" FontSize="22" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}" HorizontalOptions="Center"/>
                        <Label Text="Đã chi" TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}" Padding="12,10" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding UserRating}" FontSize="22" FontAttributes="Bold"
                               TextColor="#FFC107" HorizontalOptions="Center"/>
                        <Label Text="Đánh giá" TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ===== DARK MODE ===== -->
            <Grid Padding="20,20,20,12" ColumnDefinitions="*,Auto">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Giao diện tối" FontSize="16" TextColor="{AppThemeBinding Dark=White, Light=#111111}"/>
                    <Label Text="Bật/tắt dark mode" FontSize="12" TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}"/>
                </VerticalStackLayout>
                <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}" OnColor="#00C853"/>
            </Grid>

            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}" Margin="20,0"/>

            <!-- ===== MENU ===== -->
            <CollectionView ItemsSource="{Binding ProfileMenus}"
                            SelectionMode="Single"
                            SelectionChanged="OnMenuSelected"
                            Margin="0,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,14" ColumnDefinitions="44,*,Auto">

                            

                            <!-- Title + Desc -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Margin="12,0,0,0">
                                <Label Text="{Binding Title}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Dark=White, Light=#111111}"/>
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}"/>
                            </VerticalStackLayout>

                            <!-- Arrow -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="{AppThemeBinding Dark=#4A5068, Light=#666666}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}" Margin="20,0"/>

            <!-- ===== NÚT ĐĂNG XUẤT ===== -->
            <Button Text="Đăng xuất"
                    BackgroundColor="{AppThemeBinding Dark=#1C0A0A, Light=#FFEBEE}"
                    TextColor="Red"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="14"
                    HeightRequest="50"
                    Margin="20,24,20,0"
                    Clicked="OnLogoutClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
