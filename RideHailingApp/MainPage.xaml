<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="RideHailingApp.MainPage"
             Shell.NavBarIsVisible="False"
             Title="Đặt xe">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ===== ROW 0: HEADER ===== -->
        <Grid Grid.Row="0" BackgroundColor="{AppThemeBinding Dark=#0F1117, Light=#00C853}"
              Padding="16,44,16,12" ColumnDefinitions="Auto,*,Auto">

            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="RideNow" FontSize="20" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Dark=White, Light=#111111}"/>
                <Label x:Name="ServerStatusLabel" Text="● Server Miền Nam"
                       TextColor="#00C853" FontSize="11"/>
            </VerticalStackLayout>

            <Border Grid.Column="1" x:Name="ReadOnlyBanner" IsVisible="False"
                    BackgroundColor="#2A2200" StrokeThickness="1" Stroke="#FFC107"
                    Padding="10,6" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="⚠️" FontSize="12" VerticalOptions="Center"/>
                    <Label Text="Chế độ dự phòng • Chỉ đọc"
                           TextColor="#FFC107" FontSize="11" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Column="2"
                    BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}"
                    StrokeThickness="0" WidthRequest="38" HeightRequest="38"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                <Label x:Name="AvatarLabel" Text="N"
                       TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                       FontSize="16" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ===== ROW 1: BẢN ĐỒ ===== -->
        <Grid Grid.Row="1">
            <mapsui:MapView x:Name="MyMap"
                            VerticalOptions="FillAndExpand"
                            HorizontalOptions="FillAndExpand"/>

            <!-- Nút vị trí hiện tại -->
            <Border BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                    StrokeThickness="0" WidthRequest="44" HeightRequest="44"
                    HorizontalOptions="End" VerticalOptions="End" Margin="0,0,16,16">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <ImageButton Source="location.png" Padding="10"
                             BackgroundColor="Transparent"
                             Clicked="OnMyLocationClicked"/>
            </Border>
        </Grid>

        <!-- ===== ROW 2: PANEL CHUYỂN ĐỔI (4 trạng thái) ===== -->

        <!-- PANEL 1: Form tìm xe (trạng thái ban đầu) -->
        <Border x:Name="SearchFormPanel" Grid.Row="2"
                BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                StrokeThickness="0" Padding="16,12,16,28">
            <VerticalStackLayout Spacing="10">

                <Border BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Dark=#2E3348, Light=#CCCCCC}" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="44,*" HeightRequest="48">
                        <Label Text="📍" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="PickupEntry"
                               Placeholder="Vị trí của bạn"
                               PlaceholderColor="{AppThemeBinding Dark=#4A5068, Light=#AAAAAA}"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                               BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                        StrokeThickness="1" Stroke="#00C853" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="44,*" HeightRequest="48">
                        <Label Text="🏁" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="DestinationEntry"
                               Placeholder="Bạn muốn đi đâu?"
                               PlaceholderColor="{AppThemeBinding Dark=#4A5068, Light=#AAAAAA}"
                               TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                               BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Button x:Name="FindDriverButton"
                        Text="Tìm tài xế"
                        BackgroundColor="#00C853"
                        TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                        FontAttributes="Bold" FontSize="16" CornerRadius="14" HeightRequest="50"
                        Clicked="OnFindDriverClicked"/>

            </VerticalStackLayout>
        </Border>

        <!-- PANEL 2: Chọn loại xe + giá cước (Giai đoạn 2-3) -->
        <Border x:Name="VehicleSelectionPanel" Grid.Row="2" IsVisible="False"
                BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                StrokeThickness="0" Padding="20,16,20,28">
            <VerticalStackLayout Spacing="10">

                <BoxView WidthRequest="40" HeightRequest="4" BackgroundColor="#3E4258"
                         HorizontalOptions="Center" CornerRadius="2"/>

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Chọn loại xe" FontSize="17" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Dark=White, Light=#111}"/>
                        <Label x:Name="RouteInfoLabel" Text="" TextColor="#8A8FA3" FontSize="12"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent"
                            TextColor="#8A8FA3" FontSize="18" WidthRequest="40"
                            Clicked="OnCancelVehicleSelection"/>
                </Grid>

                <!-- Xe máy -->
                <Border x:Name="MotoOptionBorder"
                        BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#F8F8F8}"
                        StrokeThickness="2" Stroke="#00C853" Padding="14,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMotoSelected"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🛵" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="Xe máy" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"/>
                            <Label x:Name="MotoEtaLabel" Text="" TextColor="#8A8FA3" FontSize="12"/>
                        </VerticalStackLayout>
                        <Label x:Name="MotoPriceLabel" Grid.Column="2" Text=""
                               TextColor="#00C853" FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Ô tô 4 chỗ -->
                <Border x:Name="Car4OptionBorder"
                        BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#F8F8F8}"
                        StrokeThickness="2" Stroke="#2E3348" Padding="14,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCar4Selected"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚗" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="Ô tô 4 chỗ" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"/>
                            <Label x:Name="Car4EtaLabel" Text="" TextColor="#8A8FA3" FontSize="12"/>
                        </VerticalStackLayout>
                        <Label x:Name="Car4PriceLabel" Grid.Column="2" Text=""
                               TextColor="#00C853" FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Ô tô 7 chỗ -->
                <Border x:Name="Car7OptionBorder"
                        BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#F8F8F8}"
                        StrokeThickness="2" Stroke="#2E3348" Padding="14,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCar7Selected"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🚐" FontSize="24" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="Ô tô 7 chỗ" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"/>
                            <Label x:Name="Car7EtaLabel" Text="" TextColor="#8A8FA3" FontSize="12"/>
                        </VerticalStackLayout>
                        <Label x:Name="Car7PriceLabel" Grid.Column="2" Text=""
                               TextColor="#00C853" FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Tóm tắt xe đã chọn + ETA đón (AC-03, FR-04) -->
                <Border x:Name="SelectedVehicleSummary"
                        BackgroundColor="{AppThemeBinding Dark=#0D1F0D, Light=#E8F5E9}"
                        StrokeThickness="1" Stroke="#00C853" Padding="14,10">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*,*">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="Loại xe" TextColor="#4A5068" FontSize="11"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="SelectedVehicleLabel" Text="Xe máy 🛵"
                                   TextColor="#00C853" FontSize="13" FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="Giá ước tính" TextColor="#4A5068" FontSize="11"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="SelectedFareLabel" Text=""
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"
                                   FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Label Text="Tài xế đến đón" TextColor="#4A5068" FontSize="11"
                                   HorizontalOptions="Center"/>
                            <Label x:Name="SelectedEtaLabel" Text=""
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"
                                   FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Button x:Name="ConfirmBookingButton"
                        Text="Xác nhận đặt cuốc"
                        BackgroundColor="#00C853"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        CornerRadius="14" HeightRequest="52"
                        Clicked="OnConfirmBookingClicked"/>

            </VerticalStackLayout>
        </Border>

        <!-- PANEL 3: Đang tìm tài xế (Giai đoạn 3-4, ngoại lệ 6.1, 6.3) -->
        <Border x:Name="SearchingPanel" Grid.Row="2" IsVisible="False"
                BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                StrokeThickness="0" Padding="20,20,20,36">
            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                <BoxView WidthRequest="40" HeightRequest="4" BackgroundColor="#3E4258"
                         HorizontalOptions="Center" CornerRadius="2"/>

                <ActivityIndicator x:Name="SearchingIndicator" IsRunning="True"
                                   Color="#00C853" HeightRequest="40"/>

                <Label Text="Đang tìm tài xế phù hợp..."
                       TextColor="{AppThemeBinding Dark=White, Light=#111}"
                       FontSize="17" FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label x:Name="SearchingStatusLabel"
                       Text="Hệ thống đang ghép cuốc..."
                       TextColor="#8A8FA3" FontSize="13"
                       HorizontalOptions="Center"/>

                <!-- Cảnh báo mất mạng (Exception 8.5) -->
                <Border x:Name="SearchNetworkWarning" IsVisible="False"
                        BackgroundColor="#2A1A1A" StrokeThickness="1" Stroke="#FF5252"
                        Padding="10,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <Label Text="⚠️ Mất kết nối — đang thử kết nối lại..."
                           TextColor="#FF5252" FontSize="12" HorizontalOptions="Center"/>
                </Border>

                <Button Text="Hủy cuốc"
                        BackgroundColor="#C62828" TextColor="White"
                        FontAttributes="Bold" CornerRadius="14" HeightRequest="50"
                        Clicked="OnCancelTripClicked"/>

            </VerticalStackLayout>
        </Border>

        <!-- PANEL 4: Chuyến đi đang diễn ra (Giai đoạn 5-8) -->
        <Border x:Name="ActiveTripPanel" Grid.Row="2" IsVisible="False"
                BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=White}"
                StrokeThickness="0" Padding="20,16,20,28">
            <VerticalStackLayout Spacing="12">

                <BoxView WidthRequest="40" HeightRequest="4" BackgroundColor="#3E4258"
                         HorizontalOptions="Center" CornerRadius="2"/>

                <Label x:Name="TripStatusLabel"
                       Text="● Đang tìm tài xế"
                       TextColor="#FFC107" FontSize="14" FontAttributes="Bold"/>

                <!-- Thông tin tài xế (hiện sau khi tài xế nhận cuốc) -->
                <Border x:Name="DriverInfoCard" IsVisible="False"
                        BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#F5F5F5}"
                        StrokeThickness="0" Padding="14,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*">
                        <Border BackgroundColor="#00C853" StrokeThickness="0"
                                WidthRequest="44" HeightRequest="44">
                            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                            <Label x:Name="TripDriverInitial" Text="T"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label x:Name="TripDriverName" Text=""
                                   TextColor="{AppThemeBinding Dark=White, Light=#111}"
                                   FontSize="15" FontAttributes="Bold"/>
                            <Label x:Name="TripDriverPlate" Text=""
                                   TextColor="#8A8FA3" FontSize="13"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ETA tài xế đến đón realtime (AC-06, FR-07) -->
                <Border x:Name="DriverEtaBanner" IsVisible="False"
                        BackgroundColor="{AppThemeBinding Dark=#0D1F0D, Light=#E8F5E9}"
                        StrokeThickness="1" Stroke="#00C853" Padding="12,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="🚗" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="DriverEtaLabel"
                               Text="Đang cập nhật vị trí tài xế..."
                               TextColor="#00C853" FontSize="13" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Điểm đón / điểm đến -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="📍" FontSize="13" VerticalOptions="Center"/>
                    <Label x:Name="TripPickupLabel" Grid.Column="1"
                           Text="" TextColor="{AppThemeBinding Dark=White, Light=#111}"
                           FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Row="1" Text="🏁" FontSize="13" VerticalOptions="Center"/>
                    <Label x:Name="TripDropoffLabel" Grid.Row="1" Grid.Column="1"
                           Text="" TextColor="#8A8FA3" FontSize="13" VerticalOptions="Center"/>
                </Grid>

                <!-- Cảnh báo mất mạng trong active trip (Exception 8.5) -->
                <Border x:Name="ActiveNetworkWarning" IsVisible="False"
                        BackgroundColor="#2A1A1A" StrokeThickness="1" Stroke="#FF5252"
                        Padding="10,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                    <Label Text="⚠️ Mất kết nối — tạm dừng cập nhật vị trí tài xế"
                           TextColor="#FF5252" FontSize="12" HorizontalOptions="Center"/>
                </Border>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
